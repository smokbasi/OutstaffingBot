# Telegram Bot (required for live bot; leave empty for dry-run / API-only dev)
BOT_TOKEN=

# Webhook (Phase 8 production)
WEBHOOK_SECRET=
WEBHOOK_URL=

# Database (async SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://outstaffing:outstaffing@localhost:5432/outstaffing

# Redis (cache, ARQ queues — Phase 5+)
REDIS_URL=redis://localhost:6379/0

# Mini App & API URLs (dev defaults)
MINI_APP_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000

# Comma-separated Telegram user IDs with admin access
ADMIN_TELEGRAM_IDS=

# App
APP_ENV=development
LOG_LEVEL=INFO

# Optional error tracking (Phase 8 — leave empty to disable)
SENTRY_DSN=

# API server
API_HOST=0.0.0.0
API_PORT=8000
