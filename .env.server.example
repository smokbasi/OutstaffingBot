# Server-side .env template for /opt/outstaffingbot/.env
# Copy on VPS: cp .env.server.example .env && chmod 600 .env
# NEVER commit real values. See also .env.example for local dev.

# --- Telegram ---
BOT_TOKEN=
WEBHOOK_SECRET=
WEBHOOK_URL=https://www.outstaffingbot.online/webhook/SECRET

# --- App ---
APP_ENV=staging
LOG_LEVEL=INFO
# Optional: Sentry DSN (leave empty to disable)
SENTRY_DSN=
# Comma-separated Telegram user IDs (omit line if none)
# ADMIN_TELEGRAM_IDS=123456789

# --- Docker Compose / Postgres (internal network) ---
POSTGRES_USER=outstaffing
POSTGRES_PASSWORD=
POSTGRES_DB=outstaffing
DATABASE_URL=postgresql+asyncpg://outstaffing:POSTGRES_PASSWORD@postgres:5432/outstaffing

# --- Redis (internal network) ---
REDIS_URL=redis://redis:6379/0

# --- URLs (nginx + Let's Encrypt on shared VPS) ---
MINI_APP_URL=https://www.outstaffingbot.online/
API_BASE_URL=https://www.outstaffingbot.online/api

# --- API (inside compose / nginx upstream) ---
API_HOST=0.0.0.0
API_PORT=8000
